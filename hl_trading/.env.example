# Minimal — coins, strategy, leverage, and network default from `src/hl_trading/registry.py`.
# Override any of those with env vars (e.g. WATCH_COINS, HL_STRATEGY, HL_NETWORK, HL_PERP_LEVERAGE_MAP).

ACCOUNT_ADDRESS=0xYourMainWallet
API_WALLET_PRIVATE_KEY=0x...

# Optional overrides (defaults are safe for rehearsal)
# HL_NETWORK=mainnet
# DRY_RUN=true
# Cancel resting limits older than N seconds (exchange timestamp). Default 10. Set 0 to disable.
# HL_CANCEL_RESTING_AFTER_SEC=10

# Feeds / engine (defaults usually fine; see Settings in config.py)
# SUBSCRIBE_L2=true
# HL_PORTFOLIO_REFRESH_SEC=3
# HL_CANCEL_ON_MID_DRIFT_USD=0

# --- Legacy / optional ---
# METRICS_PORT=9091
# POSTGRES_DSN=postgresql://hl:hl@127.0.0.1:5432/hl
# MAX_POSITION_USD_PER_COIN=50000
# MAX_ORDER_NOTIONAL_USD=10000
