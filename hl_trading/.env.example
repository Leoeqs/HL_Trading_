# Strategy — optional `module.path:ClassName` (no-arg __init__), else NullStrategy
# SOL depth (≥1000 SOL walls near mid): use WATCH_COINS=SOL and SUBSCRIBE_L2=true
# HL_STRATEGY=hl_trading.strategies.sol_depth_strategy:SolDepthStrategy
# HL_INITIAL_PERP_LEVERAGE=1
# Default buy clip 5% of equity (~$11/order on $223 account — above HL ~$10 min). Override with SOL_DEPTH_BUY_PCT=
# SOL_DEPTH_MIN_NOTIONAL_USD=2

# Engine — refresh user_state + open orders over REST (seconds, 0=off). Default 3.
# HL_PORTFOLIO_REFRESH_SEC=3

# Cancel resting limits when |L2 mid - limitPx| exceeds this (USD). Default 0.05; 0 disables.
# HL_CANCEL_ON_MID_DRIFT_USD=0.05

# Core (required)
# Main wallet 0x… for API info (not the API agent address). Unified accounts: equity is read from
# perp clearinghouse and, if zero, from spot USDC (spotClearinghouseState).
HL_NETWORK=testnet
ACCOUNT_ADDRESS=0xYourMainWallet
API_WALLET_PRIVATE_KEY=0x...
WATCH_COINS=BTC,ETH
DRY_RUN=true

# Feeds (perps L2 is default)
SUBSCRIBE_L2=true
SUBSCRIBE_BBO=false

# Metrics — Prometheus scrapes METRICS_PORT
METRICS_PORT=9091

# Postgres — orders / fills / reconcile / pnl_daily
# POSTGRES_DSN=postgresql://hl:hl@127.0.0.1:5432/hl
# INGEST_FILLS_WS=true
# INGEST_FILL_SNAPSHOTS=false
# INGEST_FILLS_FROM_USER_EVENTS=true
# TRACK_ORDER_UPDATES=true

# ClickHouse — raw L2 NDJSON-compatible rows for replay
# CLICKHOUSE_HOST=127.0.0.1
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=default
# CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=hl

# Redis — optional live book mirror (hl:l2book:{COIN})
# REDIS_URL=redis://127.0.0.1:6379/0
REDIS_PUBLISH_L2=false

# Local high-fidelity capture (same lines as ClickHouse ingest)
# L2_LOCAL_NDJSON_PATH=/data/l2_btc.ndjson

# Risk (optional)
# MAX_POSITION_USD_PER_COIN=50000
# MAX_ORDER_NOTIONAL_USD=10000
