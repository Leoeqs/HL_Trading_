# Core (required)
HL_NETWORK=testnet
ACCOUNT_ADDRESS=0xYourMainWallet
API_WALLET_PRIVATE_KEY=0x...
WATCH_COINS=BTC,ETH
DRY_RUN=true

# Feeds (perps L2 is default)
SUBSCRIBE_L2=true
SUBSCRIBE_BBO=false

# Metrics — Prometheus scrapes METRICS_PORT
METRICS_PORT=9091

# Postgres — orders / reconcile / PnL snapshots
# POSTGRES_DSN=postgresql://hl:hl@127.0.0.1:5432/hl

# ClickHouse — raw L2 NDJSON-compatible rows for replay
# CLICKHOUSE_HOST=127.0.0.1
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=default
# CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=hl

# Redis — optional live book mirror (hl:l2book:{COIN})
# REDIS_URL=redis://127.0.0.1:6379/0
REDIS_PUBLISH_L2=false

# Local high-fidelity capture (same lines as ClickHouse ingest)
# L2_LOCAL_NDJSON_PATH=/data/l2_btc.ndjson

# Risk (optional)
# MAX_POSITION_USD_PER_COIN=50000
# MAX_ORDER_NOTIONAL_USD=10000
